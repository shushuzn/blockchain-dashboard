{
  "name": "blockchain-dashboard-backend",
  "version": "1.0.0",
  "description": "Backend API for blockchain dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":70,\"functions\":70,\"lines\":70,\"statements\":70}}'",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "lint": "eslint .",
    "migrate:create": "node migrate.js create",
    "migrate:list": "node migrate.js list",
    "migrate:status": "node migrate.js status",
    "migrate:backup": "node migrate.js backup",
    "migrate:restore": "node migrate.js restore",
    "db:init": "node init-db.js"
  },
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@apollo/server-plugin-landing-page-graphql-playground": "^4.0.1",
    "@sentry/node": "^7.109.0",
    "@sentry/profiling-node": "^1.3.5",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "graphql": "^16.8.0",
    "graphql-tag": "^2.12.6",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^6.10.1",
    "redis": "^4.7.1",
    "sequelize": "^6.37.3",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}