# Environment variables for blockchain-dashboard backend
# Copy this file to .env and fill in your values

# Server configuration
PORT=8000
NODE_ENV=development

# Database configuration
DATABASE_URL=sqlite:///database.db

# onchainos CLI path (REQUIRED for Solana meme coins feature)
# Linux/macOS: /usr/local/bin/onchainos
# Windows: C:\Users\YourUsername\.local\bin\onchainos.exe
# Railway/Render: leave empty or set to container path
ONCHAINOS_PATH=

# Security - REQUIRED
# Must be at least 32 characters with mixed case, numbers, and special characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_TO_32_CHAR_STRONG_KEY!

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_STRONG_JWT_SECRET_KEY
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Rate limiting (requests per minute)
RATE_LIMIT=100

# Logging
LOG_LEVEL=info

# Redis Cache (optional but recommended for production)
# Default: redis://localhost:6379
# Railway: REDIS_URL should be provided by Railway add-on
# Docker: Use docker-compose with redis service
REDIS_URL=redis://localhost:6379

# Cache TTL settings (in seconds)
# PRICE_TTL=60
# CHAIN_TTL=30
# LIDO_TTL=300

# CORS - Allowed origins (comma-separated)
# For production, set your frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173