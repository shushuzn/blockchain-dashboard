# Blockchain Dashboard - Environment Variables Example
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Application will fail without these
# ===========================================

# JWT Secret - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# Encryption Key - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-character-encryption-key-here

# ===========================================
# OPTIONAL - Defaults will be used if not set
# ===========================================

# Server Port
PORT=8000

# Node Environment
NODE_ENV=development

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database Path (for SQLite)
DB_PATH=./database.db

# ===========================================
# REDIS (Optional - falls back to memory cache)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# EXTERNAL APIs
# ===========================================

# CoinGecko API (free tier)
COINGECKO_API_KEY=

# 1inch API for DCA swaps
INCH_API_KEY=

# Ethereum RPC (for gas prices)
ETHEREUM_RPC=https://eth.llamarpc.com

# ===========================================
# MONITORING (Optional)
# ===========================================

# Sentry DSN for error tracking
SENTRY_DSN=

# ===========================================
# NOTIFICATIONS (Optional)
# ===========================================

# Telegram Bot (for alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_TO=alerts@example.com

# ===========================================
# MULTI-TENANT (Optional)
# ===========================================

# Admin API Key for tenant management
ADMIN_API_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
