# Environment variables for blockchain-dashboard backend

# Server configuration
PORT=8000
NODE_ENV=development

# Database configuration
DATABASE_URL=sqlite:///database.db

# onchainos CLI path (for Solana meme coins)
ONCHAINOS_PATH=C:\Users\adm\.local\bin\onchainos.exe

# Security
JWT_SECRET=your-secret-key-here

# Rate limiting (requests per minute)
RATE_LIMIT=100

# Logging
LOG_LEVEL=info