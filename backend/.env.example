# Environment variables for blockchain-dashboard backend
# Copy this file to .env and fill in your values

# Server configuration
PORT=8000
NODE_ENV=development

# Database configuration
DATABASE_URL=sqlite:///database.db

# onchainos CLI path (REQUIRED for Solana meme coins feature)
# Linux/macOS: /usr/local/bin/onchainos
# Windows: C:\Users\YourUsername\.local\bin\onchainos.exe
# Railway/Render: leave empty or set to container path
ONCHAINOS_PATH=

# Security - REQUIRED
# Must be at least 32 characters with mixed case, numbers, and special characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_TO_32_CHAR_STRONG_KEY!

# Rate limiting (requests per minute)
RATE_LIMIT=100

# Logging
LOG_LEVEL=info