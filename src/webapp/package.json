{
  "name": "blockchain-dashboard-vue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .vue,.js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,js,jsx,ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{vue,js,jsx,ts,tsx,json,css}\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@sentry/tracing": "^7.109.0",
    "@sentry/vue": "^7.109.0",
    "axios": "^1.6.8",
    "lightweight-charts": "^4.1.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-i18n": "^9.9.0",
    "vue-router": "^4.3.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.24.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "playwright": "^1.43.1",
    "prettier": "^3.2.5",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "lint-staged": {
    "*.{vue,js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
